{
  "name": "garage61-race-engineer-mcp",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "mcp",
  "workspaceFolder": "/workspaces/garage61-race-engineer-mcp",
  "overrideCommand": true,

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.debugpy",
        "Anthropic.claude-code",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "docker.docker",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/garage61-race-engineer-mcp/.venv/bin/python"
      }
    }
  },

  "postStartCommand": "git config --global --add safe.directory /workspaces/garage61-race-engineer-mcp",
  "postCreateCommand": "uv sync",
  "remoteUser": "root"
}
